#!/usr/bin/env bash

set -u

launcher_path=$(readlink -f -- "${BASH_SOURCE[0]}")
source_root=$(CDPATH= cd -- "$(dirname -- "$launcher_path")/.." && pwd)
terminal_state=
recovery_requested=false
remaining_arguments=()
state_home=${XDG_STATE_HOME:-$HOME/.local/state}
data_home=${XDG_DATA_HOME:-$HOME/.local/share}
runtime_version=$(tr -d '[:space:]' < "$source_root/sbcl.version")
runtime_command_path=$data_home/autolith/runtimes/$runtime_version/command
recorded_runtime=
if [[ -r "$runtime_command_path" ]]; then
  IFS= read -r recorded_runtime < "$runtime_command_path" || recorded_runtime=
fi
if [[ -n ${AUTOLITH_SBCL:-} ]]; then
  sbcl_command=$AUTOLITH_SBCL
elif [[ "$recorded_runtime" == /* && -x "$recorded_runtime" ]]; then
  sbcl_command=$recorded_runtime
else
  sbcl_command=sbcl
fi
export AUTOLITH_SBCL=$sbcl_command
recovery_core=${AUTOLITH_RECOVERY_CORE:-$data_home/autolith/recovery/autolith-recovery.core}
recovery_manifest=$(dirname -- "$recovery_core")/manifest.sexp
active_core=${AUTOLITH_ACTIVE_CORE:-$data_home/autolith/active/autolith-active.core}
active_manifest=$(dirname -- "$active_core")/manifest.sexp
crash_pointer=

for argument in "$@"; do
  if [[ "$argument" == "--recovery" ]]; then
    recovery_requested=true
  else
    remaining_arguments+=("$argument")
  fi
done

if [[ -t 0 ]]; then
  terminal_state=$(stty -g 2>/dev/null || true)
fi

restore_terminal()
{
  if [[ -n "$terminal_state" && -t 0 ]]; then
    stty "$terminal_state" 2>/dev/null || true
    printf '\033[?2004l\033[?25h\033[0m' > /dev/tty 2>/dev/null || true
  fi
}

finish_launcher()
{
  restore_terminal
  if [[ -n "$crash_pointer" ]]; then
    rm -f -- "$crash_pointer"
  fi
}

run_recovery()
{
  if [[ -f "$recovery_core" && -f "$recovery_manifest" ]] &&
     grep -Eq '^\(:RECOVERY-IMAGE :VERSION 2([[:space:]]|$)' "$recovery_manifest" &&
     "$sbcl_command" --noinform --core "$recovery_core" \
       --end-runtime-options "$source_root" --probe >/dev/null 2>&1; then
    "$sbcl_command" --noinform --core "$recovery_core" \
      --end-runtime-options "$source_root" "$@"
  else
    printf 'Pristine recovery image is missing or invalid; using source bootstrap. Run ./script/build-recovery to replace it.\n' >&2
    "$sbcl_command" --script "$source_root/recovery/launcher.lisp" \
      "$source_root" "$@"
  fi
}

run_active()
{
  export AUTOLITH_SOURCE_ROOT="$source_root"
  if [[ -f "$active_core" && -f "$active_manifest" ]] &&
     grep -Eq '^\(:ACTIVE-IMAGE :VERSION 1([[:space:]]|$)' "$active_manifest" &&
     "$sbcl_command" --noinform --core "$active_core" \
       --end-runtime-options "$source_root" \
       --autolith-internal-active-image-probe >/dev/null 2>&1; then
    "$sbcl_command" --noinform --core "$active_core" \
      --end-runtime-options "$source_root" "$@"
  else
    if [[ -t 2 ]]; then
      printf 'Loading Autolith from source. A cold dependency cache can take a minute.\n' >&2
      printf 'Run "%s/script/bootstrap" to install the fast startup image.\n' "$source_root" >&2
    fi
    "$sbcl_command" --script "$source_root/bin/autolith-active" "$@"
  fi
}

trap finish_launcher EXIT HUP INT TERM

if [[ "$recovery_requested" == true ]]; then
  restore_terminal
  run_recovery "${remaining_arguments[@]}"
  exit $?
fi

crash_pointer_directory="$state_home/autolith/crash-pointers"
mkdir -p -- "$crash_pointer_directory"
chmod 700 -- "$crash_pointer_directory"
crash_pointer="$crash_pointer_directory/launcher-$$.path"
rm -f -- "$crash_pointer"
export AUTOLITH_CRASH_POINTER="$crash_pointer"

if run_active "$@"; then
  exit 0
else
  status=$?
fi

restore_terminal

if [[ "$status" -ne 64 && "$status" -ne 130 && "$status" -ne 143 ]]; then
  capsule=
  if [[ -f "$crash_pointer" ]]; then
    IFS= read -r capsule < "$crash_pointer" || capsule=
    case "$capsule" in
      "$state_home/autolith/crashes/"*.sexp)
        if [[ ! -f "$capsule" ]]; then
          capsule=
        fi
        ;;
      *)
        capsule=
        ;;
    esac
  fi
  recovery_arguments=("--status" "$status")
  if [[ -n "$capsule" ]]; then
    recovery_arguments+=("--capsule" "$capsule")
  fi
  for argument in "$@"; do
    recovery_arguments+=("--original-argument" "$argument")
  done
  recovery_arguments+=("--" "$@")
  run_recovery "${recovery_arguments[@]}"
  exit $?
fi

exit "$status"
